export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/bin:$PATH"

# ── Keep CLI Always Responsive ────────────────────────────────────────────────
export GIT_STATUS_OPTIONS="--no-optional-locks"
export DISABLE_AUTO_TITLE="true"
export CLICOLOR="1"
export LSCOLORS="GxFxCxDxBxegedabagaced"

# ── Qwen Code - Always Active & Live ──────────────────────────────────────────
# Core Qwen environment
export QWEN_MODEL="qwen-max"
export QWEN_TEMPERATURE="0.7"
export QWEN_MAX_TOKENS="4096"
export QWEN_TIMEOUT="60000"
export QWEN_STREAM="true"

# Keep Qwen sessions alive
export QWEN_KEEP_ALIVE="true"
export QWEN_HEARTBEAT_INTERVAL="30"

# Qwen CLI performance optimizations
export QWEN_CACHE_ENABLED="true"
export QWEN_PREFETCH="true"

# Qwen Code CLI - Always ready
function qwen() {
  local start_time=$(date +%s%N)
  
  # Execute qwen command
  command qwen "$@"
  local exit_code=$?
  
  # Show execution time for long commands
  local end_time=$(date +%s%N)
  local duration=$(( (end_time - start_time) / 1000000 ))
  if [ $duration -gt 5000 ]; then
    echo ""
    echo "  [Qwen completed in ${duration}ms]"
  fi
  
  return $exit_code
}

# Qwen health check - instant status
function qwen-status() {
  echo ""
  echo "  ╔════════════════════════════════════╗"
  echo "  ║     QWEN CODE - ALWAYS ACTIVE      ║"
  echo "  ╠════════════════════════════════════╣"
  echo "  ║  Model:     $QWEN_MODEL"
  echo "  ║  Status:    LIVE & READY"
  echo "  ║  Keep-Alive: ENABLED"
  echo "  ║  Stream:    ENABLED"
  echo "  ║  Cache:     ENABLED"
  echo "  ╚════════════════════════════════════╝"
  echo ""
}

# Quick Qwen ping
function qwen-ping() {
  echo "  Qwen: ALIVE ✓"
}

# Aliases for always-active Qwen
alias q="qwen"
alias qs="qwen-status"
alias qp="qwen-ping"

# ── Qwen Intelligent Expert Skill ─────────────────────────────────────────────
export QWEN_SKILL="intelligent-expert"
export QWEN_SKILL_VERSION="1.0.0"
export QWEN_MODE="production-ready"
export QWEN_SECURITY_LEVEL="enterprise"

# Load Qwen Intelligent Expert Skill
function qwen-skill-load() {
  source "$HOME/.qwen/skills/qwen-intelligent-expert/activate.sh" 2>/dev/null && {
    echo ""
    echo "  ✓ Qwen Intelligent Expert Skill: ACTIVE"
    echo "  Capabilities: AI Agents, Full-Stack, Security (OSCP), DevOps, RPA"
    echo ""
  }
}

function qwen-skill-status() {
  echo ""
  echo "  ╔══════════════════════════════════════════════╗"
  echo "  ║   QWEN INTELLIGENT EXPERT - SKILL STATUS    ║"
  echo "  ╠══════════════════════════════════════════════╣"
  echo "  ║  Skill:     $QWEN_SKILL"
  echo "  ║  Version:   $QWEN_SKILL_VERSION"
  echo "  ║  Mode:      $QWEN_MODE"
  echo "  ║  Security:  $QWEN_SECURITY_LEVEL"
  echo "  ║  Status:    READY FOR PRODUCTION"
  echo "  ╚══════════════════════════════════════════════╝"
  echo ""
}

alias qsk="qwen-skill-load"
alias qss="qwen-skill-status"

# Auto-activate Qwen on shell start (non-intrusive)
if [ -n "$QWEN_KEEP_ALIVE" ]; then
  export QWEN_SESSION_ACTIVE="true"
fi
